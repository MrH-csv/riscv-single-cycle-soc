// program.hex — instrucciones RISC-V de prueba (formato $readmemh)
// Cada línea es una palabra de 32 bits en hexadecimal.
//
// Dirección  Codificación   Ensamblador
// 0x00        13000000      NOP  (ADDI x0, x0, 0)
// 0x04        93000100      ADDI x1, x0, 1       → x1 = 1
// 0x08        13010200      ADDI x2, x0, 2       → x2 = 2  (corregido abajo)
// 0x0C        33810000      ADD  x2, x1, x0      → x2 = x1 + x0
// (relleno hasta DEPTH=64)

// Instrucción 0  (PC=0x00000000): NOP
00000013
// Instrucción 1  (PC=0x00000004): ADDI x1, x0, 1  → x1 = 1
00100093
// Instrucción 2  (PC=0x00000008): ADDI x2, x0, 2  → x2 = 2
00200113
// Instrucción 3  (PC=0x0000000C): ADD  x3, x1, x2 → x3 = 3
002081b3
// Instrucción 4  (PC=0x00000010): JAL  x0, 0  (salto infinito al mismo PC)
0000006f
// Relleno con NOPs hasta completar DEPTH=64 palabras
00000013
