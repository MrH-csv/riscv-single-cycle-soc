// ============================================================
// Programa: LED chaser controlado por switches (DE2-115)
// RESET_VECTOR = 0x0040_0000
// GPIO_OUT = 0x1001_0024  (LEDs LEDR[7:0])
// GPIO_IN  = 0x1001_0028  (Switches SW[7:0])
// ============================================================
0FC10417  // 0x00: auipc s0, 0xFC10        -> s0 = 0x10010000
02440493  // 0x04: addi  s1, s0, 0x0024    -> s1 = 0x10010024 (GPIO_OUT)
02840913  // 0x08: addi  s2, s0, 0x0028    -> s2 = 0x10010028 (GPIO_IN)
00092A83  // 0x0C: lw    s5, 0(s2)         -> s5 = switches (iteraciones)
00100993  // 0x10: addi  s3, zero, 1       -> s3 = 1 (LOOP_1)
00800A13  // 0x14: addi  s4, zero, 8       -> s4 = 8
0134A023  // 0x18: sw    s3, 0(s1)         -> gpio_out = s3 (LOOP_2)
00199993  // 0x1C: slli  s3, s3, 1         -> s3 <<= 1
FFFA0A13  // 0x20: addi  s4, s4, -1        -> s4--
FE0A1AE3  // 0x24: bne   s4, zero, LOOP_2 -> si s4!=0 goto 0x18
FFFA8A93  // 0x28: addi  s5, s5, -1        -> s5--
FE0A92E3  // 0x2C: bne   s5, zero, LOOP_1 -> si s5!=0 goto 0x10
0000006F  // 0x30: jal   zero, 0           -> EXIT (loop infinito)
