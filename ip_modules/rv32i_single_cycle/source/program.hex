// ============================================================
// Programa de prueba para procesador RISC-V RV32I Single-Cycle
// Cubre: ADDI, ADD, SUB, AND, OR, SLT, SW, LW, BEQ, LUI,
//        AUIPC, JAL, NOP
// ============================================================
00500093  // 0x00: ADDI x1, x0, 5       -> x1 = 5
00A00113  // 0x04: ADDI x2, x0, 10      -> x2 = 10
002081B3  // 0x08: ADD  x3, x1, x2      -> x3 = 15
40208233  // 0x0C: SUB  x4, x1, x2      -> x4 = -5 (0xFFFFFFFB)
0020F2B3  // 0x10: AND  x5, x1, x2      -> x5 = 5 & 10 = 0
0020E333  // 0x14: OR   x6, x1, x2      -> x6 = 5 | 10 = 15
0020A3B3  // 0x18: SLT  x7, x1, x2      -> x7 = 1 (5 < 10)
00302023  // 0x1C: SW   x3, 0(x0)       -> MEM[0] = 15
00002403  // 0x20: LW   x8, 0(x0)       -> x8 = 15
00108463  // 0x24: BEQ  x1, x1, +8      -> branch taken (skip 0x28)
06300493  // 0x28: ADDI x9, x0, 99      -> SKIPPED
DEADB4B7  // 0x2C: LUI  x9, 0xDEADB    -> x9 = 0xDEADB000
00001517  // 0x30: AUIPC x10, 0x00001   -> x10 = 0x30 + 0x1000 = 0x1030
008005EF  // 0x34: JAL  x11, +8         -> x11 = 0x38, jump to 0x3C
04D00613  // 0x38: ADDI x12, x0, 77     -> SKIPPED by JAL
02A00613  // 0x3C: ADDI x12, x0, 42     -> x12 = 42
0000006F  // 0x40: JAL  x0, 0           -> infinite loop
00000013  // 0x44: NOP (padding)
00000013  // 0x48: NOP
00000013  // 0x4C: NOP
00000013  // 0x50: NOP
00000013  // 0x54: NOP
00000013  // 0x58: NOP
00000013  // 0x5C: NOP
00000013  // 0x60: NOP
00000013  // 0x64: NOP
00000013  // 0x68: NOP
00000013  // 0x6C: NOP
00000013  // 0x70: NOP
00000013  // 0x74: NOP
00000013  // 0x78: NOP
00000013  // 0x7C: NOP
00000013  // 0x80: NOP
00000013  // 0x84: NOP
00000013  // 0x88: NOP
00000013  // 0x8C: NOP
00000013  // 0x90: NOP
00000013  // 0x94: NOP
00000013  // 0x98: NOP
00000013  // 0x9C: NOP
00000013  // 0xA0: NOP
00000013  // 0xA4: NOP
00000013  // 0xA8: NOP
00000013  // 0xAC: NOP
00000013  // 0xB0: NOP
00000013  // 0xB4: NOP
00000013  // 0xB8: NOP
00000013  // 0xBC: NOP
00000013  // 0xC0: NOP
00000013  // 0xC4: NOP
00000013  // 0xC8: NOP
00000013  // 0xCC: NOP
00000013  // 0xD0: NOP
00000013  // 0xD4: NOP
00000013  // 0xD8: NOP
00000013  // 0xDC: NOP
00000013  // 0xE0: NOP
00000013  // 0xE4: NOP
00000013  // 0xE8: NOP
00000013  // 0xEC: NOP
00000013  // 0xF0: NOP
00000013  // 0xF4: NOP
00000013  // 0xF8: NOP
00000013  // 0xFC: NOP
