        <!-- ============================================================ -->
        <mxCell id="e_regtx_tx" value="&lt;font style=&quot;font-size:9px&quot;&gt;tx_data[7:0]&lt;br&gt;tx_start&lt;/font&gt;" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#E91E63;" edge="1" parent="1" source="reg_tx" target="tx_boundary">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_tx_busy" value="&lt;font style=&quot;font-size:9px&quot;&gt;tx_busy&lt;/font&gt;" style="endArrow=classic;html=1;strokeWidth=1.5;strokeColor=#E91E63;dashed=1;" edge="1" parent="1" source="tx_boundary" target="reg_status">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="620" y="350" />
              <mxPoint x="620" y="480" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_rx_data" value="&lt;font style=&quot;font-size:9px&quot;&gt;rx_data[7:0]&lt;br&gt;rx_valid&lt;/font&gt;" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#4CAF50;" edge="1" parent="1" source="rx_boundary" target="reg_rx">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="600" y="540" />
              <mxPoint x="600" y="330" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_rx_ready" value="&lt;font style=&quot;font-size:9px&quot;&gt;rx_ready&lt;/font&gt;" style="endArrow=classic;html=1;strokeWidth=1.5;strokeColor=#4CAF50;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="500" y="485" as="sourcePoint" />
            <mxPoint x="500" y="435" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- ============================================================ -->
        <!-- External Pins (right side) -->
        <!-- ============================================================ -->
        <mxCell id="pin_tx" value="&lt;b&gt;o_uart_tx&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;PIN_W15 (GPIO[0])&lt;br&gt;→ Terminal Serial&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f0f0f0;strokeColor=#999999;strokeWidth=2;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1120" y="135" width="170" height="60" as="geometry" />
        </mxCell>
        <mxCell id="pin_rx" value="&lt;b&gt;i_uart_rx&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;PIN_AK2 (GPIO[1])&lt;br&gt;← Terminal Serial&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f0f0f0;strokeColor=#999999;strokeWidth=2;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1120" y="440" width="170" height="60" as="geometry" />
        </mxCell>

        <!-- TX -> PIN -->
        <mxCell id="e_tx_pin" value="&lt;font style=&quot;font-size:9px;color:#E91E63&quot;&gt;serial out&lt;/font&gt;" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#E91E63;" edge="1" parent="1" source="tx_boundary" target="pin_tx">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- PIN -> RX -->
        <mxCell id="e_pin_rx" value="&lt;font style=&quot;font-size:9px;color:#4CAF50&quot;&gt;serial in&lt;/font&gt;" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#4CAF50;" edge="1" parent="1" source="pin_rx" target="rx_boundary">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
        <!-- Timing Parameters Box -->
        <!-- ============================================================ -->
        <mxCell id="timing_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#FFA000;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="1100" y="550" width="370" height="120" as="geometry" />
        </mxCell>
        <mxCell id="timing_title" value="&lt;b&gt;Parametros de Timing&lt;/b&gt;" style="text;html=1;align=left;fontSize=11;fontColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="1110" y="555" width="200" height="25" as="geometry" />
        </mxCell>
        <mxCell id="timing_text" value="&lt;font style=&quot;font-size:10px;font-family:monospace&quot;&gt;CLK_FREQ     = 50,000,000 Hz&lt;br&gt;BAUD_RATE    = 9,600 bps&lt;br&gt;CLKS_PER_BIT = 5,208 ciclos&lt;br&gt;Bit period   = 104.17 μs&lt;br&gt;Frame (10b)  = 1.042 ms&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="1110" y="580" width="240" height="85" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
        <!-- PC connection note -->
        <!-- ============================================================ -->
        <mxCell id="pc_note" value="&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;Terminal Serial (Docklight/PuTTY):&lt;/b&gt;&lt;br&gt;Envia byte n → SoC calcula n! → Responde 4 bytes (MSB first)&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1100" y="230" width="370" height="50" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
