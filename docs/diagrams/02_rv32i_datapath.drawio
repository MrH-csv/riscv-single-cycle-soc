        <mxCell id="branch_logic_text" value="&lt;font style=&quot;font-size:10px&quot;&gt;next_pc_sel[1:0] =&lt;br&gt;&amp;nbsp;&amp;nbsp;00 → PC + 4&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;(secuencial)&lt;br&gt;&amp;nbsp;&amp;nbsp;01 → PC + Imm&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;(branch tomado / JAL)&lt;br&gt;&amp;nbsp;&amp;nbsp;10 → rs1 + Imm&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;(JALR)&lt;br&gt;&lt;br&gt;branch_taken = branch &amp;amp; branch_cond&lt;br&gt;jal_taken = jal&lt;br&gt;jalr_taken = jalr&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
