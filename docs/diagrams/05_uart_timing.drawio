        </mxCell>

        <!-- Half bit annotation -->
        <mxCell id="half_bit_arrow" value="" style="endArrow=classic;startArrow=classic;html=1;strokeWidth=1;strokeColor=#E91E63;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="200" y="360" as="sourcePoint" />
            <mxPoint x="250" y="360" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="half_bit_label" value="&lt;font style=&quot;font-size:8px;color:#E91E63&quot;&gt;½ bit = 2604 clks&lt;/font&gt;" style="text;html=1;align=center;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="185" y="363" width="80" height="15" as="geometry" />
        </mxCell>

        <!-- Full bit annotation -->
        <mxCell id="full_bit_arrow" value="" style="endArrow=classic;startArrow=classic;html=1;strokeWidth=1;strokeColor=#1976D2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="300" y="360" as="sourcePoint" />
            <mxPoint x="380" y="360" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="full_bit_label" value="&lt;font style=&quot;font-size:8px;color:#1976D2&quot;&gt;1 bit = 5208 clks&lt;/font&gt;" style="text;html=1;align=center;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="305" y="363" width="80" height="15" as="geometry" />
        </mxCell>

        <!-- Sampling explanation -->
        <mxCell id="sampling_note" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;Estrategia:&lt;/b&gt; Al detectar flanco de bajada (start bit), se espera &lt;b&gt;½ periodo de bit&lt;/b&gt; (2604 ciclos)&lt;br&gt;para llegar al &lt;b&gt;centro&lt;/b&gt; del start bit. Se verifica que RX siga en LOW (deteccion de falso start).&lt;br&gt;Luego se muestrea cada bit de datos al centro, avanzando 1 periodo completo (5208 ciclos).&lt;br&gt;Esto maximiza el margen de tolerancia al jitter y desalineacion de relojes.&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="70" y="390" width="740" height="65" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
        <!-- Factorial Communication Sequence -->
        <!-- ============================================================ -->
        <mxCell id="seq_title" value="&lt;b&gt;Secuencia de Comunicacion: Factorial(5) = 120&lt;/b&gt;" style="text;html=1;align=left;fontSize=13;fontColor=#4A148C;" vertex="1" parent="1">
          <mxGeometry x="60" y="480" width="450" height="25" as="geometry" />
        </mxCell>

        <!-- PC (Terminal) -->
        <mxCell id="pc_actor" value="&lt;b&gt;Terminal Serial&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;(Docklight)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1976D2;strokeWidth=2;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="520" width="130" height="45" as="geometry" />
        </mxCell>

        <!-- SoC -->
        <mxCell id="soc_actor" value="&lt;b&gt;SoC RISC-V&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;(DE10-Standard)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#E91E63;strokeWidth=2;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="450" y="520" width="130" height="45" as="geometry" />
        </mxCell>

        <!-- Lifelines -->
        <mxCell id="lifeline_pc" value="" style="endArrow=none;html=1;strokeWidth=1;strokeColor=#999;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="145" y="565" as="sourcePoint" />
            <mxPoint x="145" y="830" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="lifeline_soc" value="" style="endArrow=none;html=1;strokeWidth=1;strokeColor=#999;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="515" y="565" as="sourcePoint" />
            <mxPoint x="515" y="830" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Message 1: Send n=5 -->
        <mxCell id="msg1" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;UART RX:&lt;/b&gt; envia n=5 (0x05)&lt;/font&gt;" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#1976D2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="150" y="590" as="sourcePoint" />
            <mxPoint x="510" y="590" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Processing -->
        <mxCell id="proc_box" value="&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;CPU calcula:&lt;/b&gt;&lt;br&gt;5! = 5×4×3×2×1 = 120&lt;br&gt;= 0x00000078&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#FFA000;strokeWidth=1;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="530" y="600" width="140" height="50" as="geometry" />
        </mxCell>

        <!-- Message 2-5: Send result bytes -->
        <mxCell id="msg2" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;UART TX:&lt;/b&gt; Byte 3 = 0x00 (MSB)&lt;/font&gt;" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#E91E63;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="510" y="670" as="sourcePoint" />
            <mxPoint x="150" y="670" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="msg3" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;UART TX:&lt;/b&gt; Byte 2 = 0x00&lt;/font&gt;" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#E91E63;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="510" y="710" as="sourcePoint" />
            <mxPoint x="150" y="710" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="msg4" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;UART TX:&lt;/b&gt; Byte 1 = 0x00&lt;/font&gt;" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#E91E63;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="510" y="750" as="sourcePoint" />
            <mxPoint x="150" y="750" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="msg5" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;UART TX:&lt;/b&gt; Byte 0 = 0x78 (LSB)&lt;/font&gt;" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#E91E63;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="510" y="790" as="sourcePoint" />
            <mxPoint x="150" y="790" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Loop back -->
        <mxCell id="msg6" value="&lt;font style=&quot;font-size:9px;color:#999&quot;&gt;Vuelve a WAIT_RX...&lt;/font&gt;" style="endArrow=classic;html=1;strokeWidth=1;strokeColor=#999;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="515" y="820" as="sourcePoint" />
            <mxPoint x="515" y="835" as="targetPoint" />
            <Array as="points">
              <mxPoint x="555" y="820" />
              <mxPoint x="555" y="835" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Time annotations -->
        <mxCell id="time_rx" value="&lt;font style=&quot;font-size:8px;color:#666&quot;&gt;~1.04 ms&lt;/font&gt;" style="text;html=1;align=left;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="680" y="580" width="60" height="15" as="geometry" />
        </mxCell>
        <mxCell id="time_calc" value="&lt;font style=&quot;font-size:8px;color:#666&quot;&gt;~5 ciclos (100 ns)&lt;/font&gt;" style="text;html=1;align=left;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="680" y="620" width="100" height="15" as="geometry" />
        </mxCell>
        <mxCell id="time_tx" value="&lt;font style=&quot;font-size:8px;color:#666&quot;&gt;~1.04 ms c/u&lt;br&gt;(4 × 1.04 = 4.17 ms total)&lt;/font&gt;" style="text;html=1;align=left;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="680" y="720" width="160" height="25" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
        <!-- Double FF Note -->
        <!-- ============================================================ -->
        <mxCell id="dff_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#FFA000;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="900" y="100" width="450" height="110" as="geometry" />
        </mxCell>
        <mxCell id="dff_title" value="&lt;b&gt;Sincronizador Double Flip-Flop (uart_rx)&lt;/b&gt;" style="text;html=1;align=left;fontSize=11;fontColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="910" y="105" width="350" height="25" as="geometry" />
        </mxCell>
        <mxCell id="dff_text" value="&lt;font style=&quot;font-size:10px&quot;&gt;La senal RX es asincrona respecto al reloj del FPGA.&lt;br&gt;Sin sincronizacion, puede causar &lt;b&gt;metaestabilidad&lt;/b&gt;.&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-family:monospace&quot;&gt;i_uart_rx → [FF1] rx_sync1 → [FF2] rx_sync2 → FSM&lt;/font&gt;&lt;br&gt;&lt;br&gt;Cada FF resuelve la metaestabilidad con alta probabilidad.&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="910" y="128" width="420" height="85" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
        <!-- Baud Rate Table -->
        <!-- ============================================================ -->
        <mxCell id="baud_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#7E57C2;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="900" y="240" width="450" height="180" as="geometry" />
        </mxCell>
        <mxCell id="baud_title" value="&lt;b&gt;Parametros del Baud Rate&lt;/b&gt;" style="text;html=1;align=left;fontSize=11;fontColor=#4A148C;" vertex="1" parent="1">
          <mxGeometry x="910" y="245" width="200" height="25" as="geometry" />
        </mxCell>
        <mxCell id="baud_table" value="&lt;font style=&quot;font-size:10px;font-family:monospace&quot;&gt;Parametro          Valor         Formula&lt;br&gt;─────────────────  ────────────  ──────────────────&lt;br&gt;CLK_FREQ           50,000,000    (reloj FPGA)&lt;br&gt;BAUD_RATE          9,600         (configuracion)&lt;br&gt;CLKS_PER_BIT       5,208         CLK_FREQ/BAUD_RATE&lt;br&gt;Periodo de bit     104.17 μs     1/BAUD_RATE&lt;br&gt;Periodo de frame   1.042 ms      10 × bit period&lt;br&gt;Throughput         960 B/s       BAUD_RATE/10&lt;br&gt;Error de baudrate  0.0064%       (5208.33-5208)/5208&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="910" y="270" width="410" height="140" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
