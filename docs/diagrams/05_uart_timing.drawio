          <mxGeometry x="740" y="265" width="60" height="25" as="geometry" />
        </mxCell>

        <!-- Sampling arrows (center of each bit) -->
        <mxCell id="sample_start" value="&lt;font style=&quot;font-size:8px;color:#E91E63&quot;&gt;↑ sample&lt;br&gt;½ bit&lt;/font&gt;" style="text;html=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="225" y="335" width="50" height="30" as="geometry" />
        </mxCell>
        <mxCell id="sample_d0" value="&lt;font style=&quot;font-size:8px;color:#1976D2&quot;&gt;↑&lt;/font&gt;" style="text;html=1;align=center;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="330" y="335" width="20" height="15" as="geometry" />
        </mxCell>
        <mxCell id="sample_d1" value="&lt;font style=&quot;font-size:8px;color:#1976D2&quot;&gt;↑&lt;/font&gt;" style="text;html=1;align=center;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="410" y="335" width="20" height="15" as="geometry" />
        </mxCell>
        <mxCell id="sample_d2" value="&lt;font style=&quot;font-size:8px;color:#1976D2&quot;&gt;↑&lt;/font&gt;" style="text;html=1;align=center;fontSize=12;" vertex="1" parent="1">
