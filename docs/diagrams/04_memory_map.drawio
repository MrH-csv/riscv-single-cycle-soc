          <mxGeometry x="80" y="460" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="addr_zero" value="&lt;font style=&quot;font-size:9px;font-family:monospace&quot;&gt;0x00000000&lt;/font&gt;" style="text;html=1;align=right;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="-10" y="505" width="90" height="20" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
        <!-- Peripheral Detail (right column) -->
        <!-- ============================================================ -->
        <mxCell id="periph_detail_title" value="&lt;b&gt;Detalle de Perifericos (0x10010000)&lt;/b&gt;" style="text;html=1;align=center;fontSize=13;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="520" y="65" width="320" height="30" as="geometry" />
        </mxCell>

        <!-- Address Decoder Logic -->
        <mxCell id="dec_logic" value="&lt;b&gt;Logica de Decodificacion&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;font-family:monospace&quot;&gt;&lt;br&gt;is_periph = (addr[31:16] == 16'h1001)&lt;br&gt;is_gpio   = is_periph &amp;amp; (addr[7:4] == 4'h2)&lt;br&gt;is_uart   = is_periph &amp;amp; (addr[7:4] == 4'h3)&lt;br&gt;is_dmem   = ~is_gpio &amp;amp; ~is_uart&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#FFA000;strokeWidth=1;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="490" y="100" width="360" height="100" as="geometry" />
        </mxCell>

        <!-- GPIO Registers -->
        <mxCell id="gpio_regs_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#4CAF50;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="490" y="220" width="360" height="130" as="geometry" />
        </mxCell>
        <mxCell id="gpio_regs_title" value="&lt;b&gt;GPIO Peripheral&lt;/b&gt; (addr[7:4] == 4'h2)" style="text;html=1;align=left;fontSize=11;fontColor=#2E7D32;" vertex="1" parent="1">
          <mxGeometry x="500" y="225" width="340" height="25" as="geometry" />
        </mxCell>
        <mxCell id="gpio_reg_table" value="&lt;font style=&quot;font-size:10px;font-family:monospace&quot;&gt;Offset  Nombre       Acceso  Descripcion&lt;br&gt;──────  ───────────  ──────  ─────────────────&lt;br&gt;0x20    GPIO_OUT     R/W     Salida LEDs [7:0]&lt;br&gt;0x24    GPIO_IN      R       Entrada SW [7:0]&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="505" y="250" width="330" height="70" as="geometry" />
        </mxCell>

        <!-- UART Registers -->
        <mxCell id="uart_regs_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#E91E63;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="490" y="370" width="360" height="160" as="geometry" />
        </mxCell>
        <mxCell id="uart_regs_title" value="&lt;b&gt;UART Peripheral&lt;/b&gt; (addr[7:4] == 4'h3)" style="text;html=1;align=left;fontSize=11;fontColor=#C62828;" vertex="1" parent="1">
          <mxGeometry x="500" y="375" width="340" height="25" as="geometry" />
        </mxCell>
        <mxCell id="uart_reg_table" value="&lt;font style=&quot;font-size:10px;font-family:monospace&quot;&gt;Offset  Nombre        Acceso  Descripcion&lt;br&gt;──────  ────────────  ──────  ──────────────────────&lt;br&gt;0x30    UART_TX_DATA  W       Dato a transmitir [7:0]&lt;br&gt;0x34    UART_RX_DATA  R       Dato recibido [7:0]&lt;br&gt;                              (clear-on-read)&lt;br&gt;0x38    UART_STATUS   R       {30'b0, rx_ready, tx_busy}&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="505" y="400" width="350" height="100" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
        <!-- Read MUX Priority -->
        <!-- ============================================================ -->
        <mxCell id="mux_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#7E57C2;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="490" y="555" width="360" height="110" as="geometry" />
        </mxCell>
        <mxCell id="mux_title" value="&lt;b&gt;MUX de Lectura (Address Decoder)&lt;/b&gt;" style="text;html=1;align=left;fontSize=11;fontColor=#4A148C;" vertex="1" parent="1">
          <mxGeometry x="500" y="560" width="340" height="25" as="geometry" />
        </mxCell>
        <mxCell id="mux_logic" value="&lt;font style=&quot;font-size:10px;font-family:monospace&quot;&gt;o_rdata = is_uart ? uart_rdata :&lt;br&gt;          is_gpio ? gpio_rdata :&lt;br&gt;                    dmem_rdata ;  // default&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="510" y="590" width="290" height="55" as="geometry" />
        </mxCell>
        <mxCell id="priority_note" value="&lt;font style=&quot;font-size:9px;color:#7E57C2&quot;&gt;Prioridad: UART &gt; GPIO &gt; RAM&lt;/font&gt;" style="text;html=1;align=left;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="510" y="643" width="250" height="20" as="geometry" />
        </mxCell>

        <!-- Arrow from peripheral space to detail -->
        <mxCell id="e_zoom" value="" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#FF9800;dashed=1;" edge="1" parent="1" source="periph_space" target="dec_logic">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
        <!-- AUIPC Note -->
        <!-- ============================================================ -->
        <mxCell id="auipc_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1976D2;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="490" y="690" width="360" height="90" as="geometry" />
        </mxCell>
        <mxCell id="auipc_title" value="&lt;b&gt;Calculo AUIPC para Base de Perifericos&lt;/b&gt;" style="text;html=1;align=left;fontSize=11;fontColor=#1565C0;" vertex="1" parent="1">
          <mxGeometry x="500" y="695" width="340" height="25" as="geometry" />
        </mxCell>
        <mxCell id="auipc_calc" value="&lt;font style=&quot;font-size:10px;font-family:monospace&quot;&gt;PC (inst 0) = 0x00400000&lt;br&gt;auipc s0, 0x0FC10&lt;br&gt;s0 = 0x00400000 + 0x0FC10000 = 0x10010000 ✓&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="505" y="720" width="340" height="55" as="geometry" />
        </mxCell>

