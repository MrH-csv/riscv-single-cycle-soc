        <mxCell id="addr_ram_lo" value="&lt;font style=&quot;font-size:9px;font-family:monospace&quot;&gt;0x10010000&lt;/font&gt;" style="text;html=1;align=right;fontSize=9;" vertex="1" parent="1">
