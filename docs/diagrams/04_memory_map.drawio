        <mxCell id="unused_top" value="&lt;font style=&quot;font-size:10px;color:#999&quot;&gt;No utilizado&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#BDBDBD;strokeWidth=1;" vertex="1" parent="1">
