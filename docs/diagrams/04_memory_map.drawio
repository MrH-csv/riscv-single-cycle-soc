        <!-- Unused (middle) -->
        <mxCell id="unused_mid" value="&lt;font style=&quot;font-size:10px;color:#999&quot;&gt;No utilizado&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#BDBDBD;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="320" width="240" height="60" as="geometry" />
        </mxCell>

        <!-- Instruction Memory (ROM) -->
        <mxCell id="rom_space" value="&lt;b&gt;ROM de Instrucciones&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;64 x 32-bit (256 B)&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1976D2;strokeWidth=2;" vertex="1" parent="1">
